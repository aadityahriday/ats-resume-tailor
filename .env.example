# Optional — you can also enter these directly in the app UI (recommended for non-technical users)

# ─── AI Provider Keys (configure at least one) ───────────────────

# Anthropic (Claude Opus) — Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o) — Get from: platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# Google Gemini — Get from: aistudio.google.com → Get API Key
GEMINI_API_KEY=AIzaSy...

# ─── Overleaf (required for PDF generation) ──────────────────────

# Get from: overleaf.com → F12 → Application → Cookies → overleaf_session2
OVERLEAF_SESSION_COOKIE=...
